    "zod": "^3.23.0",
    "pino": "^9.5.0",
    "chalk": "^5.3.0",
    "strip-ansi": "^7.1.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
